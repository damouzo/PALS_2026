# ==============================================================================
# data_demo/.gitignore — Privacy and reproducibility guard for the demo dataset
# ==============================================================================
#
# This file prevents multi-gigabyte 10x Genomics raw assets from ever entering
# the Git history. The repository MUST remain lean (< 10 MB tracked) so the
# pipeline can be cloned and tested on a laptop in seconds.
#
# Raw inputs (~6.5 GB) are reproducibly re-fetched by data_demo/download_data.sh.
# Processed subsets (~few MB) are reproducibly generated by
# data_demo/subsample_dataset.py.
# ==============================================================================

# Raw 10x Genomics assets (downloaded by download_data.sh).
# These files are NOT tracked, NOT diffed, and NOT linted.
raw/
!raw/.gitkeep

# Processed biological demo dataset (regenerable from raw).
# Each run of subsample_dataset.py overwrites these.
processed/*.rds
processed/*.h5ad
processed/*.h5Seurat
processed/*.csv
processed/*.tsv.gz
processed/*.tsv.gz.tbi
processed/*.xlsx
processed/*.parquet
processed/*.npz
processed/*.loom

# Helper R shim that subsample_dataset.py writes at runtime.
processed/_write_rds.R
processed/_filter_fragments.R

# Synthetic mini Seurat object (regenerable by data_demo/synthetic/build_*).
synthetic/mini_seurat.rds
synthetic/*.rds
synthetic/*.h5ad

# Runtime logs, partial downloads, lock files.
*.log
*.log.*
*.tmp
*.partial
*.lock
*.pid

# Editor / OS debris (defense in depth; the root .gitignore covers most of this).
.DS_Store
Thumbs.db
*~
*.swp
*.swo
