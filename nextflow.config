// ==============================================================================
// nextflow.config — Primary Nextflow configuration for scMultiome-GRN
// ==============================================================================
//
// Default values for every pipeline parameter. Anything declared here can be
// overridden on the CLI with --<name> <value> or by a profile (test, docker,
// singularity, conda).
//
// Profiles:
//   - standard  : use whatever the local environment provides (default).
//   - test      : use the bundled mini_seurat.rds + restrict resources.
//   - docker    : run every task in a Docker container.
//   - singularity : run every task in a Singularity container (HPC-friendly).
//   - conda     : use the unified containers/environment.yml.
//
// Author:      Daniel Mouzo
// License:     MIT
// ==============================================================================

// -----------------------------------------------------------------------------
// Default parameters
// -----------------------------------------------------------------------------
params {
    // ---- I/O ---------------------------------------------------------------
    // The default input is the BIOLOGICAL microglia dataset produced by
    // data_demo/subsample_dataset.py. To fall back to a tiny synthetic object
    // (≈ 300 KB) for ultra-fast smoke tests, see data_demo/synthetic/build_synthetic_mini_seurat.R.
    input          = "${projectDir}/data_demo/processed/microglia_dam_demo.rds"
    outdir         = "results"

    // ---- Biological defaults ----------------------------------------------
    genome         = "hg38"
    motif_db       = "gimme.vertebrate.v5.0"
    clustering     = "CellType"
    umap_key       = "umap.rna"
    clust2study    = "CT1"

    // ---- Network filtering (WOW-factor params) ---------------------------
    percentile     = 90                      // top-level, isolated on purpose
    p_threshold    = 0.001
    n_top_edges    = 2000

    // ---- In silico perturbation -------------------------------------------
    ko_targets     = "GATA1,MYB,KLF1"

    // ---- ATAC / Cicero thresholds (passed to GRN_dataProcess.R) -----------
    min_count      = 1000
    max_count      = 28000

    // ---- Execution --------------------------------------------------------
    seed           = 23
    execution_mode = "auto"                  // auto | full | synthetic
    // ---- Containers (multi-source architecture) ------------------------------
    // The R-side preprocessing is split into TWO specialized images, each
    // materialised on the fly from a Sequera Wave ORAS link (the community cache
    // at community.wave.seqera.io). Wave resolves the link to a container on the
    // target executor; no local pull is required. The conda solver stays
    // tractable because each image carries a focused set of R/Bioconductor deps:
    //   - container_r1: Wave ORAS link 79376aa02ef4e2df  (R 4.4.3 + R-essentials
    //                   + R-devtools + tidyverse + r-seurat 5.4.0 + hdf5r +
    //                   optparse + Biobase / IRanges / GenomicRanges / S4Vectors
    //                   / SummarizedExperiment / DelayedArray). Signac +
    //                   SeuratDisk are installed at runtime by bin/GRN_seurat.R.
    //   - container_r2: Wave ORAS link ffe857cbb37c1f02  (lighter base: same
    //                   R 4.4.3 + R-essentials + R-remotes + the Bioconductor
    //                   base classes). cicero + monocle3 +
    //                   EnsDb.Mmusculus.v79 are installed at runtime by
    //                   bin/GRN_cicero.R.
    // The Python-side container is a re-tag of kenjikamimoto126/celloracle_ubuntu
    // (CellOracle 0.18.0 + gimmemotifs + scanpy + anndata) hosted on Sequera's
    // private registry (ghcr.io/damouzo/pals-python-grn:1.0.0). It is pulled
    // directly via Docker — no Wave resolution is involved.
    //
    // Override per run with --container_r1, --container_r2, --container_py.
    // The legacy --container_r alias is kept for back-compat and points to
    // container_r1 (the first R-side image).
    container_r1   = "oras://community.wave.seqera.io/library/python_r-base_r-essentials_r-devtools_pruned:79376aa02ef4e2df"
    container_r2   = "oras://community.wave.seqera.io/library/python_r-base_r-essentials_r-remotes_pruned:ffe857cbb37c1f02"
    container_py   = "docker://ghcr.io/damouzo/pals-python-grn:1.0.0"
    // Legacy alias: back-compat for older invocations of --container_r.
    container_r    = null                     // resolved in process block below
    python         = "python3"               // overridable for conda envs (e.g. /path/to/conda/envs/foo/bin/python)

    // ---- Resource caps ----------------------------------------------------
    max_cpus       = 8
    max_memory     = "32.GB"
    max_time       = "4.h"
}

// -----------------------------------------------------------------------------
// Manifest
// -----------------------------------------------------------------------------
manifest {
    name            = "scMultiome-GRN"
    author          = "Daniel Mouzo"
    description     = "scMultiome GRN inference + in silico perturbation (Nextflow DSL2)."
    mainScript      = "main.nf"
    nextflowVersion = ">=25.10.0"
    version         = "0.1.0"
}

// -----------------------------------------------------------------------------
// Profiles
// -----------------------------------------------------------------------------
profiles {

    standard {
        // No container engine. The user is expected to have R + Python +
        // all dependencies available on the host.
        process.executor = "local"
        process {
            withLabel: "process_low" {
                cpus   = 1
                memory = "2.GB"
                time   = "30.m"
            }
            withLabel: "process_medium" {
                cpus   = 2
                memory = "8.GB"
                time   = "2.h"
            }
            withLabel: "process_high" {
                cpus   = 4
                memory = "16.GB"
                time   = "4.h"
            }
        }
    }

    test {
        // Use the bundled microglia_dam_demo.rds and cap resources for a laptop.
        // These caps are LOWER than the per-process labels in the modules,
        // which is the documented Nextflow way to override them at runtime.
        params.input     = "${projectDir}/data_demo/processed/microglia_dam_demo.rds"
        params.outdir    = "results"
        process.executor = "local"
        // Hard caps (the profile applies AFTER per-label directives).
        process.cpus     = 1
        process.memory   = "2.GB"
        process.time     = "30.m"
        // Per-label overrides so the demo runs on a laptop with as little
        // as 4 GB of free RAM.
        process {
            withLabel: "process_low" {
                cpus   = 1
                memory = "1.GB"
                time   = "10.m"
            }
            withLabel: "process_medium" {
                cpus   = 1
                memory = "3.GB"
                time   = "30.m"
            }
            withLabel: "process_high" {
                cpus   = 1
                memory = "3.GB"
                time   = "30.m"
            }
        }
    }

    docker {
        docker.enabled         = true
        docker.runOptions      = "-u \$(id -u):\$(id -g)"
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    conda {
        conda.enabled = true
    }
}

// -----------------------------------------------------------------------------
// Default process directives (overridden by profiles)
// -----------------------------------------------------------------------------
process {
    cpus          = 1
    memory        = "4.GB"
    time          = "2.h"
    errorStrategy = { task.attempt <= 2 ? "retry" : "finish" }
    maxRetries    = 2
    cache         = "lenient"

    // Per-process container binding. Each of the three pipeline processes
    // points to its dedicated image. --container_r (legacy alias) is mapped
    // to PREP_R_SEURAT as a back-compat fallback.
    withName: 'PREP_R_SEURAT' {
        container = params.container_r ?: params.container_r1
    }
    withName: 'PREP_R_CICERO' {
        container = params.container_r2
    }
    withName: 'INFER_GRN' {
        container = params.container_py
    }
}

// -----------------------------------------------------------------------------
// Reporting (timeline, trace, report, dag) — written into pipeline_info/
// -----------------------------------------------------------------------------
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
    fields   = "task_id,hash,native_id,name,status,exit,time,realtime,memory"
    format   = "csv"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.svg"
    overwrite = true
    render   = "dag"   // or "graph" (default) — keeps the SVG small for the demo
}
